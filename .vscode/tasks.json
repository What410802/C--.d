{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Compile Current File - BiS",
			"type": "shell",
			"group": {
				"kind": "build",
				"isDefault": true,
			},

			"command": "g++",
			"args": [
				"-Wpedantic",
				"-Wall",
				"-Wextra",
				"-std=c++17",
				"-O2",
				"-g",
				"${file}",
				"-o",
				"${fileDirname}/${fileBasenameNoExtension}.exe",
			],
			"problemMatcher": ["$gcc"],
			"presentation": {
				"echo": true,
				"reveal": "silent",
				"focus": false,
				"panel": "shared",
			},
		},
		{
			"label": "Run Only - BiS",
			"type": "shell",
			"group": {
				"kind": "test"
			},

			"command": "${fileDirname}/${fileBasenameNoExtension}.exe",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": true,
				"panel": "shared",
			},
		},
		{
			"label": "Looped Run - BiS",
			"type": "shell",
			
			"options": {
				"cwd": "${workspaceFolder}/Utility.d",
			},
			"command": "bunx", // "${command:macros.loopRunCpp}", // in `.vscode/settings.json`
			"args": [
				"ts-node",
				"${workspaceFolder}/Utility.d/ExeLoop.ts",
				"${fileDirname}/${fileBasenameNoExtension}.exe",
			],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": true,
				"panel": "shared",
			},
		},
		{
			"label": "Compile and Run - BiS",
			"type": "shell",
			"group": {
				"kind": "test"
			},

			"dependsOn": ["Compile Current File - BiS"],
			"command": "${fileDirname}/${fileBasenameNoExtension}.exe",
			"problemMatcher": ["$gcc"],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": true,
				"panel": "shared",
			},
		},
	]
}
